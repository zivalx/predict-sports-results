# WhatsApp group to post the worldcap digest to.
# Use the EXACT group name as it appears in WhatsApp Web (web.whatsapp.com).
WORLDCAP_GROUP_NAME=

# Path to the latest worldcap digest file. Relative to wa-bot/ unless absolute.
# Production default: /opt/worldcap/output/latest.md
# Dev default: ../output/latest.md
LATEST_DIGEST_PATH=../output/latest.md

# Optional footer appended to every message.
# Use \n for line breaks.
FOOTER=\nSee full details: http://localhost:8765/
