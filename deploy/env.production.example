# worldcap production environment — copy to /opt/worldcap/.env on the VPS.

# --- Database ---
# SQLite for v0 (single-host). Switch to Postgres only if scale demands.
DATABASE_URL=sqlite+aiosqlite:////opt/worldcap/data/worldcap.db

# --- Sports data ---
# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Output paths ---
DIGEST_OUTPUT_DIR=/opt/worldcap/output
WHATSAPP_PICKUP_PATH=/opt/worldcap/output/latest.md

# --- Schedule ---
# Daily refresh time (UTC cron). 09:00 UTC default.
DAILY_REFRESH_CRON=0 9 * * *

# --- Logging ---
LOG_LEVEL=INFO

# --- Claude SDK ---
ANTHROPIC_API_KEY=
SENTIMENT_MODEL=claude-haiku-4-5
RATIONALE_MODEL=claude-sonnet-4-5
RATIONALE_TOKEN_BUDGET=100000

# --- News ---
GNEWS_API_KEY=

# --- Reddit ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=worldcap/0.1 (production)
